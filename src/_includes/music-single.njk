---
layout: "music-base.njk"
---

  {# Find EPs that contain this song's title #}
  {% set parentReleases = [] %}

  {% for ep in collections.eps %}
    {% if ep.data.tracks and ep.data.tracks.includes(title) %}
      {% set parentReleases = parentReleases.concat([ep]) %}
    {% endif %}
  {% endfor %}

  {# Sort by date (latest first) #}
  {% set parentReleases = parentReleases | sort(attribute="date") | reverse %}

  {# Use nearest parent EP as fallback for listen links #}
  {% set primaryParent = null %}
  {% if parentReleases.length %}
    {% set primaryParent = parentReleases[0] %}
  {% endif %}

  {% set spotifyLink = spotify %}
  {% if not spotifyLink and primaryParent and primaryParent.data.spotify %}
    {% set spotifyLink = primaryParent.data.spotify %}
  {% endif %}

  {% set appleMusicLink = appleMusic %}
  {% if not appleMusicLink and primaryParent and primaryParent.data.appleMusic %}
    {% set appleMusicLink = primaryParent.data.appleMusic %}
  {% endif %}

  {% set bandcampLink = bandcamp %}
  {% if not bandcampLink and primaryParent and primaryParent.data.bandcamp %}
    {% set bandcampLink = primaryParent.data.bandcamp %}
  {% endif %}

  {% set youtubeLink = youtube %}
  {% if not youtubeLink and primaryParent and primaryParent.data.youtube %}
    {% set youtubeLink = primaryParent.data.youtube %}
  {% endif %}

  {# Title + badge (releaseType shown as a boxed badge) #}
  <h1 class="release-title">
    {{ title }}
    {% if releaseType %}
      <span class="release-badge" aria-hidden="true">{{ releaseType }}</span>
    {% endif %}
  </h1>

    {# Release Year (you can move this elsewhere) #}
  {% if date %}
    <p class="release-meta">{{ date.getFullYear() }}</p>
  {% endif %}

  {# Listen Links (single-line, comma-separated) #}
  {% set listenLinks = [] %}

  {% if spotifyLink %}
    {% set listenLinks = listenLinks.concat([{ name: "Spotify", url: spotifyLink }]) %}
  {% endif %}
  {% if appleMusicLink %}
    {% set listenLinks = listenLinks.concat([{ name: "Apple Music", url: appleMusicLink }]) %}
  {% endif %}
  {% if bandcampLink %}
    {% set listenLinks = listenLinks.concat([{ name: "Bandcamp", url: bandcampLink }]) %}
  {% endif %}
  {% if youtubeLink %}
    {% set listenLinks = listenLinks.concat([{ name: "YouTube", url: youtubeLink }]) %}
  {% endif %}

  {% if listenLinks.length %}
    <p class="listen-line">
      <strong>Listen on:</strong>
      {% for item in listenLinks %}
        <a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.name }}</a>{% if not loop.last %}, {% else %}.{% endif %}
      {% endfor %}
    </p>
  {% endif %}

  {% if parentReleases.length %}
    <p class="release-meta">
      <strong>Part of:</strong>
      {% for ep in parentReleases %}
        <a href="{{ ep.url | url }}">{{ ep.data.title }}</a>{% if not loop.last %}, {% else %}.{% endif %}
      {% endfor %}
    </p>
  {% endif %}

  {# Embedded Videos (responsive) #}
  {% if videoLinks %}
      <h2>Videos</h2>
      {% for link in videoLinks %}
          {% set embedUrl = link
              | replace("watch?v=", "embed/")
              | replace("youtu.be/", "www.youtube.com/embed/") %}
          <div class="video-embed">
          <iframe
              src="{{ embedUrl }}"
              frameborder="0"
              allowfullscreen>
          </iframe>
          </div>
      {% endfor %}
  {% endif %}

  {# Lyrics #}
  {% if lyrics %}
    <h2>Lyrics</h2>
    <pre class="lyrics">{{ lyrics }}</pre>
  {% endif %}
