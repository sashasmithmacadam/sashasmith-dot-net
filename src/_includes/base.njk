<!DOCTYPE html>
<html lang="en">
<head>
     <!-- Early theme application (prevents flash) -->
    <script>
        (() => {
            const storedTheme = localStorage.getItem("theme") || "system";
            const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
            const useDarkTheme = storedTheme === "dark" || (storedTheme === "system" && prefersDark);

            if (useDarkTheme) {
                document.documentElement.classList.add("dark");
            }

            document.documentElement.dataset.themePreference = storedTheme;
        })();
    </script>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{{ title }} • {{ site.title }}</title>

    <link rel="stylesheet" href="{{ '/styles/style.css' | url }}">
    <link rel="icon" type="image/png" href="{{ '/assets/images/favicon.png' | url }}">
    <link rel="apple-touch-icon" href="{{ '/assets/images/favicon.png' | url }}">
</head>
<body>
    {% set isHomePage = page.url == '/' %}
    {% set breadcrumbTrail = [] %}
    {% set breadcrumbParentKey = '' %}

    {% if not isHomePage %}
        {% if eleventyNavigation and eleventyNavigation.key %}
            {% set breadcrumbTrail = collections.all | eleventyNavigationBreadcrumb(eleventyNavigation.key, { includeSelf: true, allowMissing: true }) %}
        {% else %}
            {% if tags %}
                {% if "music" in tags %}
                    {% set breadcrumbParentKey = "Music" %}
                {% elif "essays" in tags %}
                    {% set breadcrumbParentKey = "Essays" %}
                {% elif "poem" in tags %}
                    {% set breadcrumbParentKey = "Poetry" %}
                {% elif "book-notes" in tags %}
                    {% set breadcrumbParentKey = "Book Notes" %}
                {% elif "paintings" in tags %}
                    {% set breadcrumbParentKey = "Paintings" %}
                {% elif "newsletter" in tags %}
                    {% set breadcrumbParentKey = "Newsletter" %}
                {% elif "now" in tags %}
                    {% set breadcrumbParentKey = "Now" %}
                {% endif %}
            {% endif %}

            {% if breadcrumbParentKey %}
                {% set breadcrumbTrail = collections.all | eleventyNavigationBreadcrumb(breadcrumbParentKey, { includeSelf: true, allowMissing: true }) %}
            {% endif %}
        {% endif %}
    {% endif %}

    {% if not isHomePage and tags and ("music-song" in tags) and collections.eps %}
        {% set parentEps = [] %}
        {% for ep in collections.eps %}
            {% if ep.data.tracks and ep.data.tracks.includes(title) %}
                {% set parentEps = parentEps.concat([ep]) %}
            {% endif %}
        {% endfor %}

        {% if parentEps.length %}
            {% set parentEps = parentEps | sort(attribute="date") | reverse %}
            {% set parentEp = parentEps[0] %}
            {% set lastCrumb = null %}
            {% if breadcrumbTrail and (breadcrumbTrail | length) > 0 %}
                {% set lastCrumb = breadcrumbTrail[(breadcrumbTrail | length) - 1] %}
            {% endif %}
            {% if not lastCrumb or lastCrumb.url != parentEp.url %}
                {% set breadcrumbTrail = breadcrumbTrail.concat([{ title: parentEp.data.title, url: parentEp.url }]) %}
            {% endif %}
        {% endif %}
    {% endif %}

    {% set trailIncludesCurrentPage = false %}
    {% if breadcrumbTrail and (breadcrumbTrail | length) > 0 %}
        {% set breadcrumbLastIndex = (breadcrumbTrail | length) - 1 %}
        {% set breadcrumbLast = breadcrumbTrail[breadcrumbLastIndex] %}
        {% if breadcrumbLast and breadcrumbLast.url == page.url %}
            {% set trailIncludesCurrentPage = true %}
        {% endif %}
    {% endif %}

    <header class="site-header">
        <div class="container">
            <div class="site-title{% if not isHomePage %} is-breadcrumb{% endif %}">
                <a class="site-title-home" href="{{ '/' | url }}">
                    <span class="site-title-full">{{ site.displayTitle }}</span>
                    <span class="site-title-short">S.</span>
                </a>

                {% if not isHomePage %}
                    <nav class="site-breadcrumb" aria-label="Breadcrumb">
                        {% for crumb in breadcrumbTrail %}
                            <span class="breadcrumb-separator" aria-hidden="true">→</span>
                            {% if crumb.url and crumb.url != page.url %}
                                <a href="{{ crumb.url | url }}">{{ crumb.title }}</a>
                            {% else %}
                                <span class="breadcrumb-current">{{ crumb.title }}</span>
                            {% endif %}
                        {% endfor %}

                        {% if not trailIncludesCurrentPage %}
                            <span class="breadcrumb-separator" aria-hidden="true">→</span>
                            <span class="breadcrumb-current">{{ title }}</span>
                        {% endif %}
                    </nav>
                {% endif %}
            </div>

            <nav class="site-nav">
                <!-- Main Navigation -->
                <div class="nav-menu">
                    <ul>
                        {% for item in collections.all | eleventyNavigation %}
                        <li class="
                            nav-item
                            {% if item.url == '/' %}nav-home{% endif %}
                            {% if page.url == item.url %}active{% endif %} 
                            {% if item.children and item.children | length > 0 %}has-children{% endif %}
                        ">
                            <a href="{{ item.url | url }}">
                                {{ item.title }}
                                {% if item.children and item.children | length > 0 %}
                                    <span class="submenu-toggle" aria-label="Toggle submenu">↓</span>
                                {% endif %}
                            </a>

                            {% if item.children and item.children | length > 0 %}
                                <ul class="sub-nav">
                                    {% for child in item.children %}
                                    <li class="{% if page.url == child.url %}active{% endif %}">
                                        <a href="{{ child.url | url }}">{{ child.title }}</a>
                                    </li>
                                    {% endfor %}
                                </ul>
                            {% endif %}
                        </li>
                        {% endfor %}
                    </ul>
                </div>
            </nav>
        </div>
    </header>

    <main class="content">
        {% if not hidePageTitle %}
            <h1 class="page-title">{{ title }}</h1>
        {% endif %}
        {{ content | safe }}
    </main>

    <footer>
        <p>&copy; {{ "" | year }} 
            <a href="{{ '/about/' | url }}">Sasha Smith</a> · 
            <a href="{{ '/contact/' | url }}">Say Hi</a> 👋
        </p>
        <div class="footer-theme-row">
            <div class="theme-switch" role="group" aria-label="Theme preference">
                <button type="button" class="theme-switch-option" data-theme-option="system" aria-label="Use device theme" aria-pressed="false"><span class="theme-switch-icon">🖥️</span></button>
                <button type="button" class="theme-switch-option" data-theme-option="light" aria-label="Use light theme" aria-pressed="false"><span class="theme-switch-icon">☀️</span></button>
                <button type="button" class="theme-switch-option" data-theme-option="dark" aria-label="Use dark theme" aria-pressed="false"><span class="theme-switch-icon">🌙</span></button>
            </div>
        </div>
    </footer>

    <!-- JS -->
    <script>
        /* ---------- Theme Preference ---------- */
        const THEME_STORAGE_KEY = "theme";
        const THEME_FALLBACK = "system";
        const themeButtons = document.querySelectorAll("[data-theme-option]");
        const themeMedia = window.matchMedia("(prefers-color-scheme: dark)");

        function getThemePreference() {
            const stored = localStorage.getItem(THEME_STORAGE_KEY);
            if (stored === "light" || stored === "dark" || stored === "system") {
                return stored;
            }
            return THEME_FALLBACK;
        }

        function getEffectiveTheme(preference) {
            if (preference === "dark") {
                return "dark";
            }
            if (preference === "light") {
                return "light";
            }
            return themeMedia.matches ? "dark" : "light";
        }

        function applyTheme(preference) {
            const effectiveTheme = getEffectiveTheme(preference);
            document.documentElement.classList.toggle("dark", effectiveTheme === "dark");
            document.documentElement.dataset.themePreference = preference;

            themeButtons.forEach((button) => {
                const isActive = button.dataset.themeOption === preference;
                button.classList.toggle("is-active", isActive);
                button.setAttribute("aria-pressed", isActive ? "true" : "false");
            });
        }

        function setThemePreference(preference) {
            localStorage.setItem(THEME_STORAGE_KEY, preference);
            applyTheme(preference);
        }

        applyTheme(getThemePreference());

        themeButtons.forEach((button) => {
            button.addEventListener("click", () => {
                setThemePreference(button.dataset.themeOption);
            });
        });

        const handleThemeMediaChange = () => {
            if (getThemePreference() === "system") {
                applyTheme("system");
            }
        };

        if (themeMedia.addEventListener) {
            themeMedia.addEventListener("change", handleThemeMediaChange);
        } else {
            themeMedia.addListener(handleThemeMediaChange);
        }

         /* ---------- Accordion ---------- */
        document.querySelectorAll(".accordion-toggle").forEach(button => {
            button.addEventListener("click", () => {
                const item = button.parentElement;
                const expanded = button.getAttribute("aria-expanded") === "true";

                item.classList.toggle("active");
                button.setAttribute("aria-expanded", !expanded);
            });
        });

    </script>
</body>
</html>
